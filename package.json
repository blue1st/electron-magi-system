{
  "name": "magi-system",
  "version": "1.3.2",
  "type": "module",
  "description": "MAGI System - Tripartite Consensus AI Deliberation System for Electron",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron electron/main.cjs",
    "dist": "npm run build && electron-builder",
    "release": "release-it"
  },
  "keywords": [
    "evangelion",
    "magi",
    "ai",
    "consensus",
    "deliberation",
    "electron",
    "openai"
  ],
  "author": "blue1st",
  "license": "MIT",
  "build": {
    "appId": "com.blue1st.magisystem",
    "productName": "MAGI System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "artifactName": "MAGI-System-${version}-mac.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "release-it": "^17.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0"
  }
}
